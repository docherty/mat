## mat local development environment
## Copy to `.env` and fill values. `.env` is gitignored.

# --- Core gateway ---

# Password clients must send as "Bearer <key>" when calling mat-serve.
MAT_GATEWAY_KEY=local-dev-key

# 1 = call real models. 0 = fake/offline responses (for tests).
MAT_LIVE=1

# Path to active.yaml — the list of connector IDs mat should actually use.
# Leave empty to use ./active.yaml in the repo root.
MAT_ACTIVE_POOL=

# When several local models share one LM Studio server, route through this connector id.
# active.yaml `local_primary` is used if this is empty.
MAT_LOCAL_PRIMARY=

# Folder holding all your connector YAML files (the full library).
# Leave empty to use ./connectors/library in the repo.
MAT_CONNECTORS_DIR=

# Old-style: point directly at a folder of connector YAMLs and ignore active.yaml.
# Use only if you have not migrated to library + active.yaml yet.
MAT_POOL_DIR=

# Path to a trained routing-weights file (from mat-train-live).
# Leave empty to auto-pick ~/.config/mat/coordinator/latest.json if it exists.
MAT_CHECKPOINT=

# How mat picks models: prompted | trained | slm (Trinity transcript head; pip install mat[slm])
# Leave empty to choose automatically (trained if checkpoint exists).
MAT_COORDINATOR=

# 1 = refuse to call LM Studio unless the exact model id is loaded.
# 0 = skip that check (tests only — do not use in real dev).
MAT_STRICT_LMSTUDIO_MODELS=1

# How long (seconds) to wait for each model API call before giving up.
MAT_LLM_TIMEOUT=300

# Where mat-serve listens. 127.0.0.1 = only this machine.
MAT_HOST=127.0.0.1
MAT_PORT=8080

# --- Artificial Analysis (optional) ---

# Free API key from artificialanalysis.ai — used to fetch benchmark scores
# when onboarding connectors (mat-sync-aa, mat-import-aa).
ARTIFICIAL_ANALYSIS_API_KEY=

# --- Local servers ---

# API key for your local LM Studio server, if you have one configured.
# Often left empty for default local setups.
LMSTUDIO_API_KEY=

# --- Remote API providers ---
# Only needed when a connector in your pool points at that provider.
# mat reads the key name from each connector's auth_env field — never hard-coded here.

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=

# Venice AI — https://venice.ai
VENICE_API_KEY=
