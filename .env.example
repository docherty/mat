## mat local development environment
## Copy to `.env` and fill values. `.env` is gitignored.

# --- Core ---
MAT_GATEWAY_KEY=local-dev-key
MAT_LIVE=1
MAT_POOL_DIR=
MAT_CHECKPOINT=
MAT_COORDINATOR=
MAT_STRICT_LMSTUDIO_MODELS=1
MAT_LLM_TIMEOUT=300
MAT_HOST=127.0.0.1
MAT_PORT=8080

# --- Artificial Analysis (optional, free tier key) ---
ARTIFICIAL_ANALYSIS_API_KEY=

# --- Local servers ---
LMSTUDIO_API_KEY=

# --- API providers (only needed if a connector's endpoint.auth_env points here) ---
OPENROUTER_API_KEY=
VENICE_API_KEY=

